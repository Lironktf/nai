# ============================================================
# TrustHandshake — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never expose to client
SUPABASE_ANON_KEY=your-anon-key                   # safe for client-side use

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-256-bit-hex-secret
JWT_EXPIRY=900    # seconds (15 minutes)

# ── AWS (S3 + Rekognition) ───────────────────────────────────
# IAM user needs: AmazonS3FullAccess + AmazonRekognitionFullAccess
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=trusthandshake-enrollment-videos
S3_PRESIGN_EXPIRY_SECONDS=900   # 15-minute pre-signed URL expiry

# ── Persona KYC ──────────────────────────────────────────────
PERSONA_API_KEY=your-persona-api-key
PERSONA_WEBHOOK_SECRET=your-persona-webhook-signing-secret
PERSONA_TEMPLATE_ID=your-inquiry-template-id

# ── Mobile ────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001
# Cognito Identity Pool for FaceLivenessDetector (unauthenticated access).
# Unauth role needs only: rekognition:StartFaceLivenessSession
EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EXPO_PUBLIC_AWS_REGION=us-east-1

# ── Meet Side Panel (MVP scaffold) ───────────────────────────
# Side panel frontend URL for CORS and local development
MEET_URL=http://localhost:5174
# Placeholder for Google Cloud project number used by real Meet add-on config
GOOGLE_CLOUD_PROJECT_NUMBER=123456789012
# Placeholder for deployed side-panel base URL in Google Meet add-on config
MEET_ADDON_BASE_URL=https://meet.your-domain.com
# UI fallback code prefix when Meet SDK meeting context is unavailable
VITE_MEET_FALLBACK_PREFIX=NAI

# ── Server ───────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your-bot-username
TELEGRAM_WEBHOOK_SECRET=your-webhook-signing-secret
TELEGRAM_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app
NAI_PUBLIC_AUTH_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Discord ───────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_APPLICATION_PUBLIC_KEY=your-discord-application-public-key
DISCORD_GUILD_ID=optional-dev-guild-id
# ── WebAuthn / Passkeys ───────────────────────────────────────
# RPID must be a real domain (not localhost) for passkeys on physical iOS/Android devices.
# Set to your Cloudflare tunnel domain or production domain.
RPID=nai.lironkatsif.com
# Origin the mobile app sends during WebAuthn ceremonies — must be https://<RPID>
MOBILE_ORIGIN=https://nai.lironkatsif.com
# 10-character Apple Developer Team ID (find in developer.apple.com → Membership)
# Required to serve the apple-app-site-association file for iOS passkeys.
APPLE_TEAM_ID=XXXXXXXXXX
# iOS bundle identifier (must match app.json ios.bundleIdentifier)
APP_BUNDLE_ID=com.trusthandshake.app
